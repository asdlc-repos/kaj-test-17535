y.set('status', params.status);\n  const qs = query.toString();\n  return request<LeaveRequest[]>(`/leave-requests${qs ? `?${qs}` : ''}`);\n}\n\nexport function createLeaveRequest(data: CreateLeaveRequestPayload): Promise<LeaveRequest> {\n  return request<LeaveRequest>('/leave-requests', {\n    method: 'POST',\n    body: JSON.stringify(data),\n  });\n}\n\nexport function approveLeaveRequest(id: string, payload: ReviewPayload): Promise<LeaveRequest> {\n  return request<LeaveRequest>(`/leave-requests/${id}/approve`, {\n    method: 'POST',\n    body: JSON.stringify(payload),\n  });\n}\n\nexport function rejectLeaveRequest(id: string, payload: ReviewPayload): Promise<LeaveRequest> {\n  return request<LeaveRequest>(`/leave-requests/${id}/reject`, {\n    method: 'POST',\n    body: JSON.stringify(payload),\n  });\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01WzSfkdGZPAQaGxEQxnkFiM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MwuPKFPMAie9yQKb5TxdSg","name":"Write","input":{"file_path":"/Users/kajendran/.asdlc/repos/default/kaj-test-17/leave-web-app/src/context/AuthContext.tsx","content":"import React, { createContext, useContext, useState, useCallback } from 'react';\nimport type { User, UserRole } from '../types';\n\ninterface AuthContextType {\n  user: User | null;\n  login: (employeeId: string, role: UserRole) => void;\n  logout: () => void;\n}\n\nconst AuthContext = createContext<AuthContextType | null>(null);\n\nfunction getStoredUser(): User | null {\n  try {\n    const raw = localStorage.getItem('user');\n    return raw ? (JSON.parse(raw) as User) : null;\n  } catch {\n    return null;\n  }\n}\n\nexport function AuthProvider({ children }: { children: React.ReactNode }) {\n  const [user, setUser] = useState<User | null>(getStoredUser);\n\n  const login = useCallback((employeeId: string, role: UserRole) => {\n    const u: User = { employeeId, role };\n    localStorage.setItem('user', JSON.stringify(u));\n    setUser(u);\n  }, []);\n\n  const logout = useCallback(() => {\n    localStorage.removeItem('user');\n    setUser(null);\n  }, []);\n\n  return (\n    <AuthContext.Provider value={{ user, login, logout }}>\n      {children}\n    </AuthContext.Provider>\n  );\n}\n\nexport function useAuth(): AuthContextType {\n  const ctx = useContext(AuthContext);\n  if (!ctx) throw new Error('useAuth must be used within AuthProvider');\n  return ctx;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":843,"cache_read_input_tokens":37986,"cache_creation":{"ephemeral_5m_input_tokens":843,"ephemeral_1h_input_tokens":0},"output_tokens":61,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"d7e8bf62-199f-4dd8-b4d4-7def9b222e46","uuid":"eab13844-40cb-4841-b4af-3dc19f557a38"}

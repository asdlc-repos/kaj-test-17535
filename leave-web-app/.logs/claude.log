y {\n        setLoading(false);\n      }\n    };\n\n    load();\n  }, [user, navigate, statusFilter]);\n\n  if (loading) {\n    return (\n      <Box sx={{ display: 'flex', justifyContent: 'center', mt: 8 }}>\n        <CircularProgress />\n      </Box>\n    );\n  }\n\n  return (\n    <Box>\n      <Box\n        sx={{\n          display: 'flex',\n          justifyContent: 'space-between',\n          alignItems: 'center',\n          mb: 3,\n          flexWrap: 'wrap',\n          gap: 2,\n        }}\n      >\n        <Typography variant=\"h5\">Leave History</Typography>\n        <FormControl size=\"small\" sx={{ minWidth: 160 }}>\n          <InputLabel>Filter by status</InputLabel>\n          <Select\n            value={statusFilter}\n            label=\"Filter by status\"\n            onChange={(e) => setStatusFilter(e.target.value)}\n          >\n            <MenuItem value=\"\">All</MenuItem>\n            <MenuItem value=\"pending\">Pending</MenuItem>\n            <MenuItem value=\"approved\">Approved</MenuItem>\n            <MenuItem value=\"rejected\">Rejected</MenuItem>\n          </Select>\n        </FormControl>\n      </Box>\n\n      {error && (\n        <Alert severity=\"error\" sx={{ mb: 2 }}>\n          {error}\n        </Alert>\n      )}\n\n      {requests.length === 0 ? (\n        <Typography color=\"text.secondary\">\n          No leave requests found.\n        </Typography>\n      ) : (\n        <TableContainer component={Paper}>\n          <Table>\n            <TableHead>\n              <TableRow>\n                <TableCell>Type</TableCell>\n                <TableCell>Start Date</TableCell>\n                <TableCell>End Date</TableCell>\n                <TableCell>Reason</TableCell>\n                <TableCell>Status</TableCell>\n                <TableCell>Manager Comments</TableCell>\n                <TableCell>Submitted</TableCell>\n              </TableRow>\n            </TableHead>\n            <TableBody>\n              {requests.map((req) => (\n                <TableRow key={req.id} hover>\n                  <TableCell sx={{ textTransform: 'capitalize' }}>\n                    {req.leaveType}\n                  </TableCell>\n                  <TableCell>{req.startDate}</TableCell>\n                  <TableCell>{req.endDate}</TableCell>\n                  <TableCell>{req.reason}</TableCell>\n                  <TableCell>\n                    <Chip\n                      label={req.status}\n                      color={statusColor(req.status)}\n                      size=\"small\"\n                    />\n                  </TableCell>\n                  <TableCell>{req.managerComments ?? '—'}</TableCell>\n                  <TableCell>\n                    {new Date(req.submittedAt).toLocaleDateString()}\n                  </TableCell>\n                </TableRow>\n              ))}\n            </TableBody>\n          </Table>\n        </TableContainer>\n      )}\n    </Box>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2067,"cache_read_input_tokens":43696,"cache_creation":{"ephemeral_5m_input_tokens":2067,"ephemeral_1h_input_tokens":0},"output_tokens":59,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"d7e8bf62-199f-4dd8-b4d4-7def9b222e46","uuid":"bfb86a94-836d-42cb-b025-73271e897a1e"}
